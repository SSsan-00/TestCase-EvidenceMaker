Attribute VB_Name = "MacroSuiteSingleFileInstaller"
Option Explicit

' ============================================================
' Single-file bootstrap installer
' ------------------------------------------------------------
' Import only this module, then run InstallMacroSuiteFromSingleFile.
' It recreates the current multi-module layout without changing behavior.
' ============================================================

Private Const SINGLE_FILE_MODULE_NAME As String = "MacroSuiteSingleFileInstaller"
Private Const BASE64_CHUNK_SIZE As Long = 700

Public Sub InstallMacroSuiteFromSingleFile()
    On Error GoTo ErrorHandler

    Dim vbProj As Object
    Dim tempDir As String
    Dim stepName As String

    stepName = "Precheck workbook writable"
    EnsureWorkbookWritable
    stepName = "VBProject access"
    Set vbProj = ThisWorkbook.VBProject
    stepName = "Precheck project unlocked"
    EnsureProjectUnlocked vbProj
    stepName = "Prepare temp directory"
    tempDir = PrepareSingleFileInstallerTempDir()

    stepName = "Install modules"
    InstallEmbeddedComponent vbProj, tempDir, "BetaEvidenceGenerator", GetEmbeddedBase64_BetaEvidenceGenerator(), "BetaEvidenceGenerator.bas"
    InstallEmbeddedComponent vbProj, tempDir, "BetaTestCaseGenerator", GetEmbeddedBase64_BetaTestCaseGenerator(), "BetaTestCaseGenerator.bas"
    InstallEmbeddedComponent vbProj, tempDir, "ConditionalBranchChecker", GetEmbeddedBase64_ConditionalBranchChecker(), "ConditionalBranchChecker.bas"
    InstallEmbeddedComponent vbProj, tempDir, "EscapePartsMarking", GetEmbeddedBase64_EscapePartsMarking(), "EscapePartsMarking.bas"
    InstallEmbeddedComponent vbProj, tempDir, "MacroToolsUserFormInstaller", GetEmbeddedBase64_MacroToolsUserFormInstaller(), "MacroToolsUserFormInstaller.bas"
    CleanupSingleFileInstallerTempDir tempDir
    MsgBox "ÆPłĻātā@āCāŗé®éńāéāWāģü[āŗé­ōWŖJéĄé▄éĄéĮüB" & vbCrLf & _
           "ĢKŚvé╔ē×éČé─ InstallMacroToolsUserForm / CreateMacroConfigSheet é­Ä└ŹséĄé─éŁéŠé│éóüB", vbInformation
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Len(tempDir) > 0 Then CleanupSingleFileInstallerTempDir tempDir
    On Error GoTo 0
    MsgBox "ÆPłĻātā@āCāŗé®éńé╠ōWŖJé╔ÄĖöséĄé▄éĄéĮüB" & vbCrLf & _
           "āXāeābāv: " & stepName & vbCrLf & _
           Err.Number & " : " & Err.Description & vbCrLf & vbCrLf & _
           "1004 āGāēü[é¬ÅoéķÅĻŹćé═Ä¤é­ŚLī°ē╗éĄé─éŁéŠé│éó:" & vbCrLf & _
           "Trust Center > Macro Settings > Trust access to the VBA project object model", _
           vbExclamation
End Sub

Public Sub RegenerateMacroSuiteSingleFileInstaller()
    On Error GoTo ErrorHandler

    Dim vbProj As Object
    Dim tempDir As String
    Dim templatePath As String
    Dim outputPath As String
    Dim stepName As String
    Dim templateText As String
    Dim outputText As String

    stepName = "Precheck workbook path"
    If Len(ThisWorkbook.Path) = 0 Then
        Err.Raise vbObjectError + 4205, "RegenerateMacroSuiteSingleFileInstaller", "Please save workbook before regenerating."
    End If

    stepName = "Precheck workbook writable"
    EnsureWorkbookWritable
    stepName = "VBProject access"
    Set vbProj = ThisWorkbook.VBProject
    stepName = "Precheck project unlocked"
    EnsureProjectUnlocked vbProj
    stepName = "Prepare temp directory"
    tempDir = PrepareSingleFileInstallerTempDir()

    stepName = "Export template"
    templatePath = tempDir & Application.PathSeparator & SINGLE_FILE_MODULE_NAME & ".template.bas"
    vbProj.VBComponents(SINGLE_FILE_MODULE_NAME).Export templatePath

    stepName = "Read template"
    templateText = ReadTextFileShiftJis(templatePath)

    stepName = "Build embedded block"
    outputText = ReplaceEmbeddedFunctionsBlock(templateText, BuildEmbeddedFunctionsBlock(vbProj, tempDir))

    stepName = "Write output"
    outputPath = ThisWorkbook.Path & Application.PathSeparator & SINGLE_FILE_MODULE_NAME & ".bas"
    WriteTextFileShiftJis outputPath, outputText

    CleanupSingleFileInstallerTempDir tempDir
    MsgBox "Ź─ÉČÉ¼éĄé▄éĄéĮ: " & outputPath, vbInformation
    Exit Sub

ErrorHandler:
    On Error Resume Next
    If Len(tempDir) > 0 Then CleanupSingleFileInstallerTempDir tempDir
    On Error GoTo 0
    MsgBox "ÆPłĻātā@āCāŗāCāōāXāgü[āēé╠Ź─ÉČÉ¼é╔ÄĖöséĄé▄éĄéĮüB" & vbCrLf & _
           "āXāeābāv: " & stepName & vbCrLf & _
           Err.Number & " : " & Err.Description, vbExclamation
End Sub

Private Sub InstallEmbeddedComponent(ByVal vbProj As Object, ByVal tempDir As String, ByVal componentName As String, ByVal sourceBase64 As String, ByVal fileName As String)
    Dim tempPath As String
    tempPath = tempDir & Application.PathSeparator & fileName
    WriteBase64File tempPath, sourceBase64
    RemoveComponentIfExists vbProj, componentName
    vbProj.VBComponents.Import tempPath
End Sub

Private Function PrepareSingleFileInstallerTempDir() As String
    Dim baseDir As String
    Dim tempDir As String
    baseDir = Environ$("TEMP")
    If Len(baseDir) = 0 Then Err.Raise vbObjectError + 4201, "PrepareSingleFileInstallerTempDir", "TEMP environment variable is empty."
    tempDir = baseDir & Application.PathSeparator & "codex_macro_suite_singlefile"
    If Len(Dir$(tempDir, vbDirectory)) > 0 Then CleanupSingleFileInstallerTempDir tempDir
    MkDir tempDir
    PrepareSingleFileInstallerTempDir = tempDir
End Function

Private Sub CleanupSingleFileInstallerTempDir(ByVal tempDir As String)
    On Error Resume Next
    Dim target As String
    target = tempDir & Application.PathSeparator & SINGLE_FILE_MODULE_NAME & ".template.bas"
    If Len(Dir$(target)) > 0 Then Kill target
    target = tempDir & Application.PathSeparator & "BetaEvidenceGenerator.bas"
    If Len(Dir$(target)) > 0 Then Kill target
    target = tempDir & Application.PathSeparator & "BetaTestCaseGenerator.bas"
    If Len(Dir$(target)) > 0 Then Kill target
    target = tempDir & Application.PathSeparator & "ConditionalBranchChecker.bas"
    If Len(Dir$(target)) > 0 Then Kill target
    target = tempDir & Application.PathSeparator & "EscapePartsMarking.bas"
    If Len(Dir$(target)) > 0 Then Kill target
    target = tempDir & Application.PathSeparator & "MacroToolsUserFormInstaller.bas"
    If Len(Dir$(target)) > 0 Then Kill target
    If Len(Dir$(tempDir, vbDirectory)) > 0 Then RmDir tempDir
    On Error GoTo 0
End Sub

Private Sub WriteBase64File(ByVal filePath As String, ByVal base64Text As String)
    Dim stream As Object
    Set stream = CreateObject("ADODB.Stream")
    stream.Type = 1
    stream.Open
    stream.Write DecodeBase64ToBytes(base64Text)
    stream.SaveToFile filePath, 2
    stream.Close
End Sub

Private Function DecodeBase64ToBytes(ByVal base64Text As String) As Variant
    Dim xmlDoc As Object
    Dim xmlNode As Object
    Set xmlDoc = CreateObject("MSXML2.DOMDocument.6.0")
    Set xmlNode = xmlDoc.createElement("b64")
    xmlNode.DataType = "bin.base64"
    xmlNode.Text = base64Text
    DecodeBase64ToBytes = xmlNode.nodeTypedValue
End Function

Private Function BuildEmbeddedFunctionsBlock(ByVal vbProj As Object, ByVal tempDir As String) As String
    Dim specs As Variant
    Dim spec As Variant
    Dim tempPath As String
    Dim base64Text As String
    specs = GetSingleFileComponentSpecs()
    For Each spec In specs
        tempPath = tempDir & Application.PathSeparator & CStr(spec(1))
        vbProj.VBComponents(CStr(spec(0))).Export tempPath
        base64Text = EncodeBytesToBase64(ReadBinaryFileBytes(tempPath))
        AppendBufferLine BuildEmbeddedFunctionsBlock, "Private Function GetEmbeddedBase64_" & CStr(spec(0)) & "() As String"
        AppendBufferLine BuildEmbeddedFunctionsBlock, "    Dim encoded As String"
        AppendBase64AssignmentLines BuildEmbeddedFunctionsBlock, base64Text
        AppendBufferLine BuildEmbeddedFunctionsBlock, "    GetEmbeddedBase64_" & CStr(spec(0)) & " = encoded"
        AppendBufferLine BuildEmbeddedFunctionsBlock, "End Function"
        AppendBufferLine BuildEmbeddedFunctionsBlock, vbNullString
    Next spec
End Function

Private Sub AppendBase64AssignmentLines(ByRef buffer As String, ByVal base64Text As String)
    Dim startPos As Long
    Dim partText As String
    For startPos = 1 To Len(base64Text) Step BASE64_CHUNK_SIZE
        partText = Mid$(base64Text, startPos, BASE64_CHUNK_SIZE)
        AppendBufferLine buffer, "    encoded = encoded & """ & partText & """"
    Next startPos
End Sub

Private Function ReplaceEmbeddedFunctionsBlock(ByVal templateText As String, ByVal generatedBlock As String) As String
    Dim blockStart As Long
    Dim lastBlockStart As Long
    Dim blockEnd As Long
    Dim firstSignature As String
    Dim lastSignature As String
    firstSignature = "Private Function GetEmbeddedBase64_" & GetFirstEmbeddedComponentName() & "() As String"
    lastSignature = "Private Function GetEmbeddedBase64_" & GetLastEmbeddedComponentName() & "() As String"
    blockStart = InStr(1, templateText, firstSignature, vbBinaryCompare)
    If blockStart = 0 Then Err.Raise vbObjectError + 4206, "ReplaceEmbeddedFunctionsBlock", "Embedded block start not found."
    lastBlockStart = InStr(1, templateText, lastSignature, vbBinaryCompare)
    If lastBlockStart = 0 Then Err.Raise vbObjectError + 4207, "ReplaceEmbeddedFunctionsBlock", "Embedded block end not found."
    blockEnd = FindFunctionBlockEnd(templateText, lastBlockStart)
    ReplaceEmbeddedFunctionsBlock = Left$(templateText, blockStart - 1) & generatedBlock & Mid$(templateText, blockEnd + 1)
End Function

Private Function FindFunctionBlockEnd(ByVal sourceText As String, ByVal functionStart As Long) As Long
    Dim endPos As Long
    endPos = InStr(functionStart, sourceText, "End Function", vbBinaryCompare)
    If endPos = 0 Then Err.Raise vbObjectError + 4208, "FindFunctionBlockEnd", "End Function not found."
    FindFunctionBlockEnd = endPos + Len("End Function") - 1
    If Mid$(sourceText, FindFunctionBlockEnd + 1, 2) = vbCrLf Then
        FindFunctionBlockEnd = FindFunctionBlockEnd + 2
    ElseIf Mid$(sourceText, FindFunctionBlockEnd + 1, 1) = vbLf Then
        FindFunctionBlockEnd = FindFunctionBlockEnd + 1
    End If
End Function

Private Function GetSingleFileComponentSpecs() As Variant
    Dim specs(0 To 4) As Variant

    specs(0) = Array("BetaEvidenceGenerator", "BetaEvidenceGenerator.bas")
    specs(1) = Array("BetaTestCaseGenerator", "BetaTestCaseGenerator.bas")
    specs(2) = Array("ConditionalBranchChecker", "ConditionalBranchChecker.bas")
    specs(3) = Array("EscapePartsMarking", "EscapePartsMarking.bas")
    specs(4) = Array("MacroToolsUserFormInstaller", "MacroToolsUserFormInstaller.bas")

    GetSingleFileComponentSpecs = specs
End Function

Private Function GetFirstEmbeddedComponentName() As String
    Dim specs As Variant
    Dim firstSpec As Variant

    specs = GetSingleFileComponentSpecs()
    firstSpec = specs(LBound(specs))
    GetFirstEmbeddedComponentName = CStr(firstSpec(0))
End Function

Private Function GetLastEmbeddedComponentName() As String
    Dim specs As Variant
    Dim lastSpec As Variant

    specs = GetSingleFileComponentSpecs()
    lastSpec = specs(UBound(specs))
    GetLastEmbeddedComponentName = CStr(lastSpec(0))
End Function

Private Function ReadBinaryFileBytes(ByVal filePath As String) As Variant
    Dim stream As Object
    Set stream = CreateObject("ADODB.Stream")
    stream.Type = 1
    stream.Open
    stream.LoadFromFile filePath
    ReadBinaryFileBytes = stream.Read
    stream.Close
End Function

Private Function EncodeBytesToBase64(ByVal fileBytes As Variant) As String
    Dim xmlDoc As Object
    Dim xmlNode As Object
    Set xmlDoc = CreateObject("MSXML2.DOMDocument.6.0")
    Set xmlNode = xmlDoc.createElement("b64")
    xmlNode.DataType = "bin.base64"
    xmlNode.nodeTypedValue = fileBytes
    EncodeBytesToBase64 = Replace$(Replace$(CStr(xmlNode.Text), vbCr, vbNullString), vbLf, vbNullString)
End Function

Private Function ReadTextFileShiftJis(ByVal filePath As String) As String
    Dim stream As Object
    Set stream = CreateObject("ADODB.Stream")
    stream.Type = 2
    stream.Charset = "shift-jis"
    stream.Open
    stream.LoadFromFile filePath
    ReadTextFileShiftJis = stream.ReadText
    stream.Close
End Function

Private Sub WriteTextFileShiftJis(ByVal filePath As String, ByVal text As String)
    Dim stream As Object
    Set stream = CreateObject("ADODB.Stream")
    stream.Type = 2
    stream.Charset = "shift-jis"
    stream.Open
    stream.WriteText text
    stream.SaveToFile filePath, 2
    stream.Close
End Sub

Private Sub EnsureWorkbookWritable()
    If ThisWorkbook.ReadOnly Then
        Err.Raise vbObjectError + 4202, "EnsureWorkbookWritable", "Workbook is read-only."
    End If
End Sub

Private Sub EnsureProjectUnlocked(ByVal vbProj As Object)
    On Error GoTo AccessError
    If CInt(vbProj.Protection) <> 0 Then
        Err.Raise vbObjectError + 4203, "EnsureProjectUnlocked", "VBA project is protected."
    End If
    Exit Sub
AccessError:
    Err.Raise vbObjectError + 4204, "EnsureProjectUnlocked", "Unable to inspect VBA project protection: " & Err.Description
End Sub

Private Sub RemoveComponentIfExists(ByVal vbProj As Object, ByVal componentName As String)
    Dim component As Object
    For Each component In vbProj.VBComponents
        If StrComp(component.Name, componentName, vbTextCompare) = 0 Then
            vbProj.VBComponents.Remove component
            Exit For
        End If
    Next component
End Sub

Private Sub AppendBufferLine(ByRef buffer As String, ByVal lineText As String)
    If Len(buffer) = 0 Then
        buffer = lineText
    Else
        buffer = buffer & vbCrLf & lineText
    End If
End Sub

